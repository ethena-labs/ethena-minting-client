    "openapi:init": "next-openapi-gen init"
  },
  "dependencies": {
    "@scalar/nextjs-api-reference": "^0.9.9",
    "next": "^16.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.19.7",
    "@types/react": "^19.2.9",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.39.2",
    "eslint-config-next": "^16.0.0",
    "next-openapi-gen": "^0.9.4",
    "typescript": "^5.9.3"
  }
}

