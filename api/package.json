{
  "name": "@ethena/minting-api-docs",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "pnpm run openapi:generate && next build",
    "start": "next start",
    "lint": "eslint .",
    "type-check": "tsc --noEmit",
